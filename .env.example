VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public R2 URL, either an r2.dev URL or a custom domain.
# Example: https://media.example.com
VITE_R2_PUBLIC_URL=
VITE_SUPABASE_TIMEOUT_MS=4000

# Optional table overrides. Leave these as-is if you use supabase/schema.sql.
VITE_SUPABASE_MODELS_TABLE=models
VITE_SUPABASE_CATEGORIES_TABLE=categories
VITE_SUPABASE_GALLERY_IMAGES_TABLE=gallery_images

# Supabase Edge Function secrets, set with `supabase secrets set`.
# SITE_URL=https://www.dominio.com
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
